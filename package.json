{
  "name": "travel-magazine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_TLS_REJECT_UNAUTHORIZED=0&& next dev -H 0.0.0.0 -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "import:country": "npx --yes tsx scripts/import-country.ts",
