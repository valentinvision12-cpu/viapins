    "clsx": "^2.1.1",
    "framer-motion": "^12.9.4",
    "geist": "^1.3.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-intl": "^3.26.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
