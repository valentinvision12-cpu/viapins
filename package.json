    "resolve:places": "node scripts/resolve-osm-places.mjs",
    "resolve:places:free": "node scripts/resolve-osm-places.mjs",
    "fix:all-countries": "node scripts/fix-all-countries.mjs",
    "resolve:google-places": "node scripts/resolve-google-places.mjs",
    "refresh:images": "npx --yes tsx scripts/refresh-place-images.ts",
    "verify:images": "npx --yes tsx scripts/verify-place-images.ts"
  },
  "dependencies": {
