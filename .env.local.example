# ============================================================
# TRAVEL MAGAZINE - Environment Variables Template
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Supabase ---
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google Cloud Translation API ---
# Get from: https://console.cloud.google.com/apis/credentials
# Required for auto-translating non-core languages
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key-here

# --- Google Maps / Places API ---
# Enable "Places API (New)" in Google Cloud Console
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --- Claude AI API (Module 2) ---
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Unsplash API (Module 2) ---
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical production origin for OG + Schema.org @id URLs.
# Do not set NEXT_PUBLIC_SITE_URL to a *.vercel.app host - getSiteUrl() falls back to viapins.com.
NEXT_PUBLIC_SITE_URL=https://viapins.com

# --- Search engine verification (optional — paste tokens from each console) ---
# Google Search Console → Settings → Ownership verification → HTML tag content=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → meta name="msvalidate.01" content=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
# Yandex Webmaster → meta name="yandex-verification" content=
NEXT_PUBLIC_YANDEX_VERIFICATION=
# IndexNow (Bing/Yandex instant URL submission) — random UUID, then POST /api/indexnow
INDEXNOW_KEY=
# Optional shared secret for POST /api/indexnow (Bearer token). Admins can also call with session.
INDEXING_API_SECRET=
# Google Indexing API — service account (Owner on Search Console property)
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=
# or paste full JSON:
# GOOGLE_INDEXING_SERVICE_ACCOUNT_JSON=


# Mapbox GL JS (public token — restrict by URL in Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# --- Admin protection (production) ---
# Optional extra gate: browser asks for username/password before /admin/login
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASSWORD=choose-a-strong-password-here

# Local dev only — NEVER set true on Vercel production
# SKIP_ADMIN_AUTH=true
